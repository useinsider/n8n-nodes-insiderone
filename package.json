{
	"name": "n8n-nodes-insiderone",
	"version": "1.0.0",
	"description": "n8n community node for Insider One integration",
	"license": "MIT",
	"homepage": "https://github.com/useinsider/n8n-nodes-insiderone",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Insider One",
		"email": "info@useinsider.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/useinsider/n8n-nodes-insiderone.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"start": "n8n-node build && n8n start",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/InsiderOneApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/InsiderOne/InsiderOne.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"concurrently": "^9.2.1",
		"eslint": "9.39.4",
		"nodemon": "^3.1.14",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
